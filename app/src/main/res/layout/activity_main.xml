<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Radar -->
    <com.reconradar.app.hud.RadarView
        android:id="@+id/radar_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="76dp" />

    <!-- HUD overlay -->
    <com.reconradar.app.hud.HudOverlayView
        android:id="@+id/hud_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="76dp" />

    <!-- Control bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_gravity="bottom"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp">

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="@string/ready"
            android:textColor="@color/hud_text_dim"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_scan"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@color/bg_card"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/btn_scan"
                android:textColor="@color/radar_green"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_baseline"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@color/bg_card"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/btn_baseline"
                android:textColor="@color/hud_accent"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btn_clear"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@color/bg_card"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/btn_clear"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
